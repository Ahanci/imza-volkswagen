# ===================================================
# İmza Volkswagen - Environment Variables (ÖRNEK)
# ===================================================
# Gerçek değerleri .env.local veya Vercel dashboard'da tutun.
# Bu dosyayı (örnek değerlerle) repoya ekleyebilirsiniz.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.imzavolkswagen.com.tr
NEXT_PUBLIC_SITE_NAME="İmza Volkswagen"

# --- İletişim (public) ---
NEXT_PUBLIC_PHONE=+905321234567
NEXT_PUBLIC_WHATSAPP=+905321234567
NEXT_PUBLIC_EMAIL=info@imzavolkswagen.com.tr

# --- Analytics (opsiyonel) ---
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# --- Form backend (ileride - iletişim formu / newsletter için) ---
# RESEND_API_KEY=
# CONTACT_FORM_TO_EMAIL=
